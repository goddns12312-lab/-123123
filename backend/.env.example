# ─────────────────────────────────────────────────────────────────
#  backend/.env.example
#  완전 무료 스택: Supabase (PostgreSQL) + Render (Web Service)
#
#  사용법:
#    cp .env.example .env
#    .env 파일을 열어 Supabase 연결 정보를 입력하세요.
# ─────────────────────────────────────────────────────────────────

# ── 서버 설정 ──────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ── Supabase 연결 정보 ────────────────────────────────────────────
# 확인 경로: Supabase Dashboard → 프로젝트 선택 → Settings → API
#
# Project URL  (예: https://xxxxxxxxxxx.supabase.co)
SUPABASE_URL=https://your-project-id.supabase.co

# service_role key (비밀키 — 절대 클라이언트에 노출 금지!)
# Dashboard → Settings → API → "service_role" 섹션의 key 복사
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your_service_role_key_here

# ── JWT 설정 ───────────────────────────────────────────────────────
# 최소 32자 이상 랜덤 문자열 (openssl rand -base64 32 로 생성 가능)
JWT_SECRET=your_super_secret_key_change_this_in_production_min_32chars
JWT_EXPIRES_IN=24h

# ── 관리자 기본 계정 ───────────────────────────────────────────────
# Render 배포 시 반드시 안전한 값으로 변경하세요
ADMIN_USER=admin
ADMIN_PASS=admin1234

# ── CORS 허용 출처 ─────────────────────────────────────────────────
# 쉼표로 구분. 배포 후 실제 URL로 교체하세요.
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ── Rate Limit ────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
