{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "casino-root",
  "compatibility_date": "2026-03-09",

  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "casino-production",
      "database_id": "local-casino-production",
      "migrations_dir": "./migrations"
    }
  ]
}
